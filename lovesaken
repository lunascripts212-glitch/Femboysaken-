local function processInBatches(items, cb, bs, delay)
    bs = bs or 3; delay = delay or 0.15
    if #items == 0 then return end
    local i = 1
    local function go()
        local n = 0
        while i <= #items and n < bs do
            cb(items[i]); i = i + 1; n = n + 1
        end
        if i <= #items then task.delay(delay, go) end
    end
    go()
end

