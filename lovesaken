-- ==================== WAIT FOR MODULES ====================
local function waitForModules()
    local maxAttempts = 10
    local attempt = 0
    while attempt < maxAttempts do
        local net = ReplicatedStorage:FindFirstChild("Modules")
        if net then
            local actorsMod = net:FindFirstChild("Actors")
            if actorsMod then return true end
        end
        task.wait(0.5)
        attempt = attempt + 1
    end
    return false
end

local function tryApplyCrystalPatch()
    if S.crystalPitchEnabled then
                if waitForModules() then
            CrystalPitch.patch()
        end
    end
end

